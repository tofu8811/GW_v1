# Application
APP_NAME=gateway-api
APP_ENV=development
APP_PORT=8080

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=gateway_db
POSTGRES_USER=gateway_user
POSTGRES_PASSWORD=gateway_password
DATABASE_URL=postgres://gateway_user:gateway_password@localhost:5432/gateway_db?sslmode=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# Config cache loader
CONFIG_SCHEMA_VERSION=1
CONFIG_POLL_INTERVAL_SECONDS=20
CONFIG_TTL_SECONDS=0
CONFIG_REBUILD_LOCK_TTL_SECONDS=10
CONFIG_REBUILD_LOCK_WAIT_SECONDS=2

# Upstream health checks
HEALTH_CHECK_INTERVAL=10s
HEALTH_PROBE_TIMEOUT=2s
HEALTH_UNHEALTHY_THRESHOLD=3
HEALTH_HEALTHY_THRESHOLD=2
HEALTH_KEY_TTL=30s

# Upstream circuit breaker
BREAKER_FAILURE_THRESHOLD=5
BREAKER_OPEN_TIMEOUT=15s
BREAKER_HALFOPEN_MAX=1

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin123

# Auth
JWT_SECRET=change_me_in_local_env
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=168h

# Logging
LOG_LEVEL=debug

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_LOG_INDEX_PREFIX=gateway-logs
